{
  "name": "isaac-decrafting-tool",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "serve": "SET NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service serve",
    "build": "SET NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build && node transform.js",
    "build:web": "SET NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service build",
    "lint": "SET NODE_OPTIONS=--openssl-legacy-provider && vue-cli-service lint",
    "electron:dev": "npm run build:web && electron .",
    "electron:build": "npm run build:web && electron-builder --win portable",
    "electron:build:installer": "npm run build:web && electron-builder --win"
  },
  "dependencies": {
    "@babel/core": "^7.16.5",
    "@babel/preset-env": "^7.16.5",
    "@popperjs/core": "^2.11.0",
    "bootstrap": "^5.1.3",
    "core-js": "^3.6.5",
    "es3ify": "^0.2.2",
    "es3ify-mw": "^0.2.4",
    "esprima": "^4.0.1",
    "node": "^17.3.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@vue/cli-plugin-babel": "~4.5.0",
    "@vue/cli-plugin-eslint": "~4.5.0",
    "@vue/cli-service": "~4.5.0",
    "@vue/compiler-sfc": "^3.0.0",
    "babel-eslint": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^6.7.2",
    "eslint-plugin-vue": "^7.0.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "rules": {}
  },
  "browserslist": [
    "IE 8"
  ],
  "build": {
    "appId": "com.broknsun.isaac-decrafting-tool",
    "productName": "Isaac Decrafting Tool",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
